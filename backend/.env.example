# Secrets must be at least 32 characters in production
RUST_LOG=info
DATABASE_URL=sqlite://data/devstage.db
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32chars
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=604800
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@devstage.local
SMTP_TLS_INSECURE=false
MAGIC_LINK_BASE_URL=http://localhost:5173/auth/verify
SERVER_PORT=3000
CORS_ORIGIN=http://localhost:5173
